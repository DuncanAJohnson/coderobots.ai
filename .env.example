# Copy to .env.local and fill in per deployment.

# Which instance config to build (src/config/instances/<id>.js).
# Defaults to 'purdue' when unset.
VITE_INSTANCE=purdue

# --- Required when the instance has telemetry: true (Supabase persistence + auth) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Modal chat endpoint with per-user budget enforcement (chat.mode: 'direct').
VITE_MODAL_BUDGET_ENDPOINT_URL=

# --- Required when the instance has chat.mode: 'tutor' ---
# Modal tutor pipeline endpoint (modal deploy modal_functions/tutor_pipeline.py).
VITE_MODAL_TUTOR_ENDPOINT_URL=

# --- Required when the instance offers the 'esp32-arduino' platform ---
# Modal Arduino compile service (modal deploy modal_functions/esp32_compile.py).
VITE_ESP32_COMPILE_URL=

# --- Optional / legacy ---
# Plain chat endpoint without budget tracking (legacy streamChatCompletion).
VITE_MODAL_ENDPOINT_URL=

